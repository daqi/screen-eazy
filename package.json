{
  "name": "camshadow-mvp",
  "version": "0.1.0",
  "description": "CamShadow camera-only floating overlay",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "icon:mac": "bash scripts/make-mac-icon.sh",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "npm run icon:mac && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.camshadow.app",
    "productName": "CamShadow",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "static/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "CamShadow 需要访问摄像头以显示悬浮人像画面。"
      }
    }
  }
}
